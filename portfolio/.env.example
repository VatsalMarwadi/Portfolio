# Copy to .env for local development (never commit .env)

SECRET_KEY=your-django-secret-key
DJANGO_DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com
# CSRF_TRUSTED_ORIGINS=https://your-service.onrender.com

# Database — Option A: URL (Render Postgres sets DATABASE_URL automatically)
# DATABASE_URL=postgres://user:password@host:5432/dbname
# DATABASE_SSL_REQUIRE=True

# Database — Option B: local PostgreSQL
DB_NAME=portfolio_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Cloudinary (project preview images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (contact form)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=your@gmail.com
CONTACT_ADMIN_EMAIL=your@gmail.com
