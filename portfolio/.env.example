# Copy to .env and fill in real values (never commit .env to GitHub)

SECRET_KEY=your-django-secret-key-here
DJANGO_DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app

# Database — use ONE of these options:

# Option A: single URL (recommended for Render + Neon/Supabase/Railway)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME
# DATABASE_SSL_REQUIRE=True

# Option B: local PostgreSQL
DB_NAME=portfolio_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Cloudinary (project preview images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Legacy names also supported:
# CLOUD_NAME=
# API_KEY=
# API_SECRET=

# Email (contact form)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=your@gmail.com
CONTACT_ADMIN_EMAIL=your@gmail.com
